# Copy this file to .env and fill in real values.
# Never commit the real .env file.

# MongoDB connection string
# Local:  mongodb://localhost:27017/delivery_management
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/delivery_management
MONGO_URL=mongodb://localhost:27017/delivery_management

# Port the API listens on
PORT=3000

# Secret used to sign JWT tokens.
# Generate a strong one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Google Maps Platform API key with the Distance Matrix API enabled
GOOGLE_API_KEY=replace-with-your-google-api-key
