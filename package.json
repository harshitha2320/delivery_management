{
  "name": "delivery-management-api",
  "version": "1.0.0",
  "description": "REST API for delivery management with JWT authentication, inventory and order handling, and delivery route optimisation using the Google Distance Matrix API (nearest-neighbour + 2-opt).",
  "author": "Harshitha",
  "license": "MIT",
  "main": "src/server.js",
  "scripts": {
    "start": "node ./src/server.js",
    "dev": "nodemon ./src/server.js",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\"",
    "test": "jest --runInBand"
  },
  "keywords": [
    "express",
    "mongodb",
    "rest-api",
    "jwt",
    "route-optimisation",
    "delivery"
  ],
  "dependencies": {
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.5.0",
    "mongoose": "^8.7.3",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "supertest": "^7.2.2"
  }
}
